{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/track/layout,_N_T_/dashboard/track/page,_N_T_/dashboard/track"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/track/__PAGE__",
    "/dashboard/track",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}